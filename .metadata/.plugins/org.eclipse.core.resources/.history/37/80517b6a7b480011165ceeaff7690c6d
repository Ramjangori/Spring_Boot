package in.h.controller;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Controller;
import org.springframework.ui.Model;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.ModelAttribute;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestParam;

import in.h.entity.User;
import in.h.service.UserService;

@Controller
public class MyController {

	@Autowired
	UserService service;

	@GetMapping("/register")
	public String openRegPage(Model model) {

		model.addAttribute("user", new User());

		return "Register";
	}

	@PostMapping("/userSubmit")
	public String submitReg(@ModelAttribute("user") User user,
	                        Model model,
	                        @RequestParam("confirmPassword") String cnpass) {


	    if(user.getPass() == null || !user.getPass().equals(cnpass)) {
	        model.addAttribute("mismatch", "Password Not Matched");
	        return "Register";
	    }

	    String email = user.getEmail();
	    User find = service.CheckUser(email);

	    if (find != null) {
	        model.addAttribute("error", "Email already exists, please login");
	        return "Register";
	    }

	    boolean status = service.registerUser(user);

	    if (status) {
	        model.addAttribute("success", "User Registered Successfully");
	        return "login";
	    }

	    model.addAttribute("error", "Registration Failed");
	    return "Register";
	}
	
	@GetMapping("/login")
	public String login(Model model) {
		model.addAttribute("user", new User());
		return "login";
	}

	@PostMapping("/loginreq")
	public String userLogin(@ModelAttribute("user") User user, Model model) {

	    String email = user.getEmail();
	    String pass = user.getPass();
	    System.out.println("Email: " + email);
	    System.out.println("Pass: " + pass);

	    User validUser = service.loginUser(email, pass);

	    System.out.println("User found: " + validUser);



	    if (validUser != null) {
	        return "redirect:/home";  
	    }

	    model.addAttribute("error", "Invalid Email or Password");
	    return "login";
	}
	
	@GetMapping("/home")
	public String homePage() {
	    return "home";   
	}
}


