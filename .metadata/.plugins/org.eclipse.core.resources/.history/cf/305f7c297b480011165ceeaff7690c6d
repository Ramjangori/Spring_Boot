<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hospital Management</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', sans-serif;
        }

        body {
            height: 100vh;
            background: linear-gradient(135deg, #4facfe, #00f2fe);
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* Card */
        .container {
            text-align: center;
            background: rgba(255, 255, 255, 0.2);
            backdrop-filter: blur(15px);
            padding: 45px 30px;
            border-radius: 16px;
            box-shadow: 0 15px 30px rgba(0,0,0,0.2);
            width: 360px;
            color: #fff;
            animation: fadeIn 0.8s ease-in-out;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        h1 {
            font-size: 28px;
            margin-bottom: 10px;
        }

        p {
            font-size: 14px;
            margin-bottom: 30px;
            opacity: 0.9;
        }

        /* Buttons */
        .btn {
            display: block;
            width: 100%;
            padding: 12px;
            margin: 12px 0;
            text-decoration: none;
            border-radius: 8px;
            font-weight: bold;
            transition: 0.3s;
            letter-spacing: 0.5px;
        }

        .register {
            background: #1abc9c;
            color: white;
        }

        .register:hover {
            background: #16a085;
            transform: scale(1.03);
        }

        .login {
            background: #3498db;
            color: white;
        }

        .login:hover {
            background: #2980b9;
            transform: scale(1.03);
        }

        /* Footer */
        .footer {
            margin-top: 15px;
            font-size: 12px;
            opacity: 0.8;
        }

    </style>
</head>

<body>

<div class="container">
    <h1>🏥 E-Hospital</h1>
    <p>Manage Patients, Doctors & Appointments Easily</p>

    <a href="/register" class="btn register">🚀 Register</a>
    <a href="/login" class="btn login">🔐 Login</a>

    <div class="footer">
        © 2026 E-Hospital System
    </div>
</div>

</body>
</html>