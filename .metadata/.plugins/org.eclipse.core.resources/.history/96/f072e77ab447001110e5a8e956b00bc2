package in.h.service;

import in.h.entity.User;
import in.h.repository.UserRepo;

public class UserServiceImpl implements UserService {
	  UserRepo userrepo;

	@Override
	public boolean registerUser(User user) {
		 
		  try {
			   
			    userrepo.save(user);
			    return true;
		  }
		  catch(Exception e) {
			  e.printStackTrace();
		  }
		
		return false;
	}

}
